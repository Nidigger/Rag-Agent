# Server overrides
HOST=0.0.0.0
PORT=8000
CORS_ALLOW_ORIGINS=["http://localhost:5174","http://127.0.0.1:5174"]
LOG_LEVEL=INFO
FASTAPI_INTERNAL_TOKEN=your-internal-token

# Model
DASHSCOPE_API_KEY=your-key
CHAT_MODEL_NAME=qwen3-max
EMBEDDING_MODEL_NAME=text-embedding-v4
OPENAI_COMPATIBLE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Qdrant vector store
VECTOR_PROVIDER=qdrant
QDRANT_URL=http://192.168.31.104:6333
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION_NAME=rag_agent_knowledge
QDRANT_VECTOR_SIZE=1536
QDRANT_DISTANCE=Cosine
VECTOR_INGEST_CHUNK_SIZE=600
VECTOR_INGEST_CHUNK_OVERLAP=80
VECTOR_INGEST_BATCH_SIZE=64

# Chroma / RAG overrides (fallback)
CHROMA_PERSIST_DIR=chroma_db
CHROMA_K=3
CHUNK_SIZE=200
CHUNK_OVERLAP=20
DATA_DIR=data
EXTERNAL_DATA_PATH=data/external/records.csv
